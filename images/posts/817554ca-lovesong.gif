fb25583c-1c1a-46c1-a31c-0fb9fef3122e/P3600395-Astrocyte_nerve_cell_2x3.jpg"},{"nm":"3x4","aspRto":0.75,"url":"https://i.natgeofe.com/n/fb25583c-1c1a-46c1-a31c-0fb9fef3122e/P3600395-Astrocyte_nerve_cell_3x4.jpg"},{"nm":"4x3","aspRto":1.3333333333333333,"url":"https://i.natgeofe.com/n/fb25583c-1c1a-46c1-a31c-0fb9fef3122e/P3600395-Astrocyte_nerve_cell_4x3.jpg"},{"nm":"2x1","aspRto":2,"url":"https://i.natgeofe.com/n/fb25583c-1c1a-46c1-a31c-0fb9fef3122e/P3600395-Astrocyte_nerve_cell_2x1.jpg"}],"rt":"https://i.natgeofe.com/n/fb25583c-1c1a-46c1-a31c-0fb9fef3122e/P3600395-Astrocyte_nerve_cell.jpg","src":"https://i.natgeofe.com/n/fb25583c-1c1a-46c1-a31c-0fb9fef3122e/P3600395-Astrocyte_nerve_cell.jpg","dsc":"Fluorescent light microscope of an astrocyte cell from a human brain. Glial-fibrillary acidic protein, a type of intermediate filament (IF), part of the cell's cytoskeleton, has been dyed green. Cell nuclei, which contain the cell's genetic information, have been dyed blue. The nuclei of fibroblast cells are seen in the background. Astrocytes are a type of glial cell. They provide structural support and protection for neurons (nerves cells) and also supply them with nutrients and oxygen. The cells cannot transmit electric signals and so insulate neurons from one another.","ttl":"P3600395-Astrocyte_nerve_cell"},"title":"Are these brain cells the key to treating trauma and anxiety?","abTest":{"testId":"ng_pw_copy-287","variantId":"variant_a-1126","type":"paywallTest","variant":"variant_a","abTest":"ng_pw_copy-287*variant_a-1126"}},{"id":"aff612da-f3f9-405b-b9d2-cc3d0f43e049","cmsType":"RegularStandardPrismTile","isPremium":true,"isEntitled":false,"isFreemium":false,"isUserAuthed":false,"pageType":"home","storyId":"drn:src:natgeo:unison::prod:8c1779b3-8042-4594-864d-a45d14779e15","cId":"aff612da-f3f9-405b-b9d2-cc3d0f43e049_8c1779b3-8042-4594-864d-a45d14779e15","ctas":[{"url":"https://www.nationalgeographic.com/health/article/fasting-exercise-health-benefits"}],"img":{"crps":